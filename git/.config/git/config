[merge]
	conflictstyle = diff3
[alias]
	untrack = update-index --assume-unchanged
	track = update-index --no-assume-unchanged
[color]
	ui = auto
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = cyan
[color "status"]
	added = green
	changed = yellow
	untracked = red

; Integration.

[core]
	excludesfile = ~/.local/share/git/ignore
[include]
	path = ~/.local/share/git/config
