#!/usr/bin/env zsh

set -e -o pipefail -u

function main() {
	local module_dir
	for module_dir in "$@"; do
		do_module "$module_dir"
	done
}

function do_module() {
	local module_dir="$1"

	[[ ! -e "$module_dir" ]] && return 0

	do_module_unhome "$module_dir" || echo "error" >&2
	do_module_home "$module_dir" || echo "error" >&2
	do_module_unbin "$module_dir" || echo "error" >&2
	do_module_bin "$module_dir" || echo "error" >&2
	do_module_unconfig "$module_dir" || echo "error" >&2
	do_module_config "$module_dir" || echo "error" >&2
	do_module_unintegration_zsh "$module_dir" || echo "error" >&2
	do_module_integration_zsh "$module_dir" || echo "error" >&2
	do_module_brewfile "$module_dir" || echo "error" >&2
}

function do_module_home() (
	local module_dir="$1"
	local remote_dir="$(get_home_dir)"
	local local_dir="$module_dir/.home"

	[[ ! -e "$local_dir" ]] && return 0

	local f
	for f in "$local_dir/"*(D); do
		symlink "$remote_dir/$(basename "$f")" "$f"
	done
)

function do_module_unhome() (
	local module_dir="$1"
	local remote_dir="$(get_home_dir)"
	local local_dir="$module_dir/.home"

	[[ ! -e "$remote_dir" ]] && return 0

	local f
	for f in "$remote_dir/"*(D); do
		unsymlink "$f" "$module_dir"
	done
)

