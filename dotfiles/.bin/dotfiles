	local module_dir="$1"
	local remote_dir="$(get_integration_zsh_dir)"
	local local_dir="$module_dir/.integration/zsh"

	[[ ! -e "$local_dir" ]] && return 0

	local f
	for f in "$local_dir/"*(D); do
